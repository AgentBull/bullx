{
  "packageManager": "bun@1.3.13",
  "scripts": {
    "setup": "mix deps.get && mix ecto.setup && bun install && mix assets.build",
    "dev": "iex -S mix phx.server",
    "rsbuild:dev": "bun --bun rsbuild dev --log-level warn",
    "build": "bun --bun rsbuild build",
    "fmt": "mix format && cargo fmt --all",
    "fmt:check": "mix format --check-formatted && cargo fmt --all --check",
    "lint:js": "bun --bun rslint webui/src",
    "lint": "bun --bun turbo run lint:js fmt:check --output-logs=new-only",
    "test": "bun --bun rstest run",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test:elixir": "MIX_ENV=test mix test",
    "compile": "MIX_ENV=test mix compile --warnings-as-errors",
    "i18n": "MIX_ENV=test mix i18n.check",
    "deps:unused": "mix deps.unlock --unused",
    "precommit": "bun --bun turbo run lint:js test fmt:check deps:unused compile i18n test:elixir --output-logs=new-only"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@fontsource-variable/geist": "^5.2.8",
    "@inertiajs/react": "^3.0.3",
    "@remixicon/react": "^4.9.0",
    "axios": "^1.15.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "i18next": "^26.0.8",
    "input-otp": "^1.4.2",
    "json-edit-react": "^1.29.0",
    "messageformat": "^4.0.0",
    "next-themes": "^0.4.6",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-i18next": "^17.0.6",
    "shadcn": "^4.5.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@iarna/toml": "^3.0.0",
    "@rsbuild/core": "^2.0.3",
    "@rsbuild/plugin-react": "^2.0.0",
    "@rslint/core": "^0.5.1",
    "@rstest/adapter-rsbuild": "^0.2.6",
    "@rstest/core": "^0.9.9",
    "@storybook/addon-docs": "^10.3.4",
    "@storybook/addon-themes": "^10.3.4",
    "@storybook/react": "^10.3.4",
    "@tailwindcss/postcss": "^4.2.4",
    "happy-dom": "^20.8.9",
    "storybook": "^10.3.5",
    "storybook-react-rsbuild": "^3.3.3",
    "tailwindcss": "^4.2.4",
    "turbo": "^2.9.6",
    "typescript": "^6.0.3"
  }
}
