// This file enables editor support for the React/Inertia asset tree.
// Rsbuild resolves Phoenix JavaScript packages through aliases in rsbuild.config.ts.
{
  "compilerOptions": {
    "paths": {
      "@/*": ["./webui/src/*"],
      "@locales/*": ["./priv/locales/client/*"]
    },
    "allowJs": true,
    "noEmit": true
  },
  "include": ["webui/src/**/*"]
}
